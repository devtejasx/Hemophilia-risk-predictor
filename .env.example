# ========================================
# HEMOPHILIA AI PLATFORM - PRODUCTION CONFIG
# ========================================

# === ENVIRONMENT ===
# Options: development, staging, production
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# === API CONFIGURATION ===
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Hemophilia AI Platform API
API_VERSION=2.0.0
FRONTEND_URL=http://localhost:8501

# === OPENAI API CONFIGURATION ===
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TIMEOUT=60

# === SECURITY ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_random_32_character_hex_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === DATABASE ===
# For SQLite (development):
DATABASE_URL=sqlite:///./hemophilia_clinic.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/hemophilia_db
DB_CONNECTION_TIMEOUT=30
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# === RATE LIMITING ===
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# === LOGGING ===
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# === CACHING ===
CACHE_ENABLED=True
CACHE_TTL_SECONDS=3600

# === ML MODELS ===
MODELS_PATH=./models
RF_MODEL_PATH=./models/rf.pkl
XGB_MODEL_PATH=./models/xgb.pkl
COLUMNS_PATH=./models/columns.pkl
BATCH_SIZE_PREDICTIONS=32
MAX_BATCH_SIZE=1000

# === CORS (Comma-separated Origins) ===
# Update these for production domain
CORS_ORIGINS=http://localhost,http://localhost:8501,http://localhost:3000

# === HEALTH CHECK ===
HEALTH_CHECK_INTERVAL=60

# === OPTIONAL: EMAIL NOTIFICATIONS ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=admin@yourdomain.com

# === OPTIONAL: MONITORING & LOGGING ===
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
DATADOG_API_KEY=your_datadog_api_key

# === DATABASE BACKUP ===
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
